  "summary": {
    "title": "litestar-admin: Modern Admin Panel for Litestar",
    "description": "A production-ready admin panel framework for Litestar applications with Cloudflare dashboard-inspired UI, CRUD operations, RBAC, audit logging, and SQLAlchemy/Advanced-Alchemy integration.",
    "goals": [
      "Create a Litestar-native admin plugin with InitPluginProtocol",
      "Build a modern Next.js frontend with static export (no Node.js runtime)",
      "Implement full CRUD operations for SQLAlchemy models",
      "Provide flexible authentication (JWT, OAuth2)",
      "Enable RBAC permission system with audit logging",
      "Design for extensibility and customization"
    ],
    "constraints": [
      "Frontend: Next.js static export only (no SSR runtime)",
      "Tooling: oxlint and oxfmt for frontend (not ESLint/Prettier)",
      "Styling: Tailwind CSS 4.x with dark theme",
      "Backend: Python 3.10+, Litestar 2.x, Advanced-Alchemy",
      "Database: SQLAlchemy 2.x async only"
    ],
    "estimated_duration": "12 weeks",
    "priority": "high"
  },
